# =============================================================================
# Telecom Fault Intelligence — Backend Environment Variables
# Copy this file to .env and fill in your values.
# =============================================================================

# --- OpenAI (required) -------------------------------------------------------
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_MODEL=gpt-3.5-turbo

# --- ChromaDB (local persistent storage, no cloud key needed) ----------------
CHROMA_DB_PATH=./Data/chroma_db

# --- FastAPI server -----------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
API_RELOAD=true

# --- Data --------------------------------------------------------------------
DATASET_PATH=./Data/telecom_dataset_merged.csv
CHUNK_SIZE=500
CHUNK_OVERLAP=100

# --- Search ------------------------------------------------------------------
BM25_K1=2.0
BM25_B=0.75
HYBRID_ALPHA=0.5
TOP_K_RETRIEVAL=5
RERANK_TOP_K=3

# --- Evaluation --------------------------------------------------------------
EVALUATION_ENABLED=true
DEEPEVAL_MODEL=gpt-3.5-turbo
DEEPEVAL_THRESHOLD=0.7

# --- Logging -----------------------------------------------------------------
LOG_LEVEL=INFO
LOG_FILE=./logs/telecom_fault.log

# --- CORS / Frontend ---------------------------------------------------------
# Comma-separated list of allowed origins.
# http://localhost:5173 and http://localhost:3000 are always allowed in code
# regardless of this setting, so the default below is sufficient for dev.
FRONTEND_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Development -------------------------------------------------------------
DEBUG=false
ENVIRONMENT=development
